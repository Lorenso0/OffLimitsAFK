{
  "scripts": [
    {
      "id": "zombies-afk-automatic-guns",
      "name": "Automatic Guns",
      "kind": "ahk",
      "entry": "scripts/Automatic Guns.ahk",
      "description": "AHK automatic guns loop with held left click, V press, and periodic X. Toggle with 8 and exit with F2.",
      "args": [],
      "setup": [
        "Open Black Ops Zombies and focus the game before toggling.",
        "Tap 8 to start or stop the automatic guns loop.",
        "Use F2 to fully exit the script."
      ],
      "keybinds": [
        {
          "key": "toggle_key",
          "label": "Toggle Script",
          "flag": "--toggle-key",
          "value": "8",
          "placeholder": "8"
        },
        {
          "key": "exit_key",
          "label": "Exit Script",
          "flag": "--exit-key",
          "value": "F2",
          "placeholder": "F2"
        },
        {
          "key": "scoreboard_key",
          "label": "Scoreboard Toggle",
          "flag": "--scoreboard-key",
          "value": "sc029",
          "placeholder": "sc029"
        },
        {
          "key": "melee_key",
          "label": "Melee",
          "flag": "--melee-key",
          "value": "v",
          "placeholder": "v"
        }
      ],
      "timings": [
        {
          "key": "scoreboard_toggling",
          "label": "Scoreboard toggling",
          "flag": "--scoreboard-toggling",
          "value": "1",
          "false_value": "0",
          "control": "checkbox",
          "suffix": ""
        },
        {
          "key": "hold_lmb_time",
          "label": "Hold Left Click",
          "flag": "--hold-lmb-time",
          "value": "65",
          "suffix": "ms"
        },
        {
          "key": "v_wait_time",
          "label": "Wait after Melee",
          "flag": "--v-wait-time",
          "value": "430",
          "suffix": "ms"
        }
      ],
      "accent": "#6d28d9"
    },
